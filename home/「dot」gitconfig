[user]
  name = emp.justine
  email = emp.justine@gmail.com

[color]
  branch = auto
  diff = auto
  interactive = auto
  status = auto
  ui = auto

# Solarized color theme ------------------------------------------------------
[color "branch"]
  current = yellow reverse
  local = yellow
  remote = green
[color "diff"]
  meta = yellow bold
  frag = magenta bold
  old = red bold
  new = green bold

# ----------------------------------------------------------------------------

[core]
  # Recognize mixed spaces and tabs as a whitespace problem
  whitespace = space-before-tab
  # System-wide .gitignore file
  excludesfiles = '~/.gitignore'

[format]
  pretty = format:%C(blue)%ad%Creset %C(yellow)%h%C(green)%d%Creset %C(blue)%s %C(magenta) [%an]%Creset

[push]
  # 'git push' will push the current branch to its tracking branch
  # the usual default is to push all branches
	default = current

[merge]
  summary = true
  verbosity = 1
  # Always show a diffstat at the end of a merge
  stat = true

[diff]
  # Git diff will use (i)ndex, (w)ork tree, (c)ommit and (o)bject
  # instead of a/b/c/d as prefixes for patches
  mnemonicprefix = true
  # Allow git diff to do basic rename and copy detection
  renames = copies

[branch]
  # When branching off a remote branch, automatically let the local branch
  # track the remote branch
  autosetupmerge = true

[rerere]
  # Remember my merges and resolved conflicts
  # http://gitfu.wordpress.com/2008/04/20/git-rerere-rereremember-what-you-did-last-time/
  enabled = true

[gui]
  fontui = -family DINPro -size 9 -weight normal -slant roman -underline 0 -overstrike 0
  fontdiff = -family \"Inconsolata\" -size -12 -weight normal -slant roman -underline 0 -overstrike 0
  commitmsgwidth = 80

[alias]
  ush = push
  ull = pull
[status]
	submodulesummary = true
