#!/bin/sh

export DE="xmonad"
export DESKTOP_SESSION="xmonad"

. sources $DOTFILES_ROOT/x.d/*

####
#keymap
setxkbmap -model abnt2 -layout br -variant abnt2 &
numlockx &

####
#mouse pointer
xsetroot -cursor_name left_ptr &
unclutter &

####
#disable pc speaker beep
xset -b &

####
#set DPI to "redmond" 96
xrandr --dpi 96

/usr/lib/polkit-gnome/polkit-gnome-authentication-agent-1

firefox &
keepassx &
vlc &
uxterm -e rosetta-network-dhcpcd-start &
uxterm -e rosetta-network-wlan-start &
uxterm &

exec xmonad

