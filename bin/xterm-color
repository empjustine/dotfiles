#!/usr/bin/env ruby

module XTerm

  XTERM_ESCAPE_START = "\033]"
  XTERM_ESCAPE_END   = "\007"
  SOLARIZED_BACKGROUND = [0x00, 0x2b, 0x36] # S_base03
  SOLARIZED_FOREGROUND = [0x83, 0x94, 0x96] # S_base0

  class << self

    def escape(*code)
      print "#{XTERM_ESCAPE_START}#{[*code].join(";")}#{XTERM_ESCAPE_END}"
    end

    def colour(number, _colour)
      escape 4, number, _colour
    end

    def foreground(_colour)
      escape 10, _colour
    end

    def background(_colour)
      escape 11, _colour
    end
  end
end

def compress(value, min=0, max=255)
  if value < min
    value = min
  elsif value > max
    value = max
  else
    value
  end
end

def rand_colour(base, delta=8)
  return "##{
    base.map { |channel_colour|
      "%02X" % compress(channel_colour - delta + rand(delta * 2 + 1))
    }.join
  }"

end

def main

  exit 1 unless ENV['TERM'][/xterm/]

  XTerm.background rand_colour XTerm::SOLARIZED_BACKGROUND
  XTerm.foreground rand_colour XTerm::SOLARIZED_FOREGROUND
end

if __FILE__ == $0
  main
end