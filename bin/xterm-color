#!/usr/bin/env ruby

module XTerm

  XTERM_ESCAPE_START = "\033]"
  XTERM_ESCAPE_END   = "\007"
  SOLARIZED_BACKGROUD = [0x00, 0x2b, 0x36]

  class << self

    def escape(*code)
      puts "#{XTERM_ESCAPE_START}#{[*code].join(";")}#{XTERM_ESCAPE_END}"
    end

    def colour(number, _colour)
      escape 4, number, _colour
    end

    def foreground(_colour)
      escape 10, _colour
    end

    def backgroud(_colour)
      escape 11, _colour
    end
  end
end

rand_half_range = 16
rand_colour = "##{XTerm::SOLARIZED_BACKGROUD.map { |source_colour|
  colour = source_colour - rand_half_range + rand(rand_half_range * 2 + 1)
  if colour < 0
    colour = 0
  elsif colour > 255
    colour = 255
  end

  "%02X" % colour
}.join}"

XTerm.backgroud rand_colour