#!/bin/sh

_valkyrja_name=$1

if valkyrja-wahr "$_valkyrja_name"; then
  valkyrja-exec "$_valkyrja_name" 'chmod 0755 ~'
  valkyrja-exec "$_valkyrja_name" 'mkdir  -p  ~/prefix'
  valkyrja-exec "$_valkyrja_name" 'chmod 0755 ~/prefix'

  valkyrja-exec "$_valkyrja_name" 'mkdir  -p  ~/environment'
  valkyrja-exec "$_valkyrja_name" 'chmod 0755 ~/environment'

  valkyrja-exec "$_valkyrja_name" 'mkdir  -p  ~/environment/override'
  valkyrja-exec "$_valkyrja_name" 'chmod 0755 ~/environment/override'

  valkyrja-exec "$_valkyrja_name" 'mkdir  -p  ~/environment/colon_append'
  valkyrja-exec "$_valkyrja_name" 'chmod 0755 ~/environment/colon_append'

  valkyrja-exec "$_valkyrja_name" 'date +%Y-%m-%dT%H:%M:%S%Z%z > birthday'
else
  echo "${0##*/}: must choose a valkyrja."
  exit 1
fi
